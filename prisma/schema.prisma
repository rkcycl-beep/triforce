generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  COACH
  ATHLETE
}

enum Sport {
  RUN
  RIDE
  SWIM
  ALL
}

enum ChallengeType {
  DISTANCE
  TIME
  TRAINING_LOAD
  PACE
  STEPS
  ELEVATION
}

model User {
  id                      String    @id @default(cuid())
  email                   String    @unique
  name                    String?
  avatarUrl               String?
  role                    Role      @default(ATHLETE)

  // Strava
  stravaId                String?   @unique
  stravaAccessToken       String?
  stravaRefreshToken      String?
  stravaTokenExpiresAt    DateTime?

  // Profile
  dateOfBirth             DateTime?
  gender                  String?   // "M" | "F" | "X"

  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  // Relations
  coachedGroups           Group[]              @relation("CoachGroups")
  memberships             GroupMembership[]
  activities              Activity[]
  challengeEntries        ChallengeEntry[]
  createdChallenges       Challenge[]

  @@map("users")
}

model Group {
  id          String    @id @default(cuid())
  name        String
  description String?
  coachId     String
  coach       User      @relation("CoachGroups", fields: [coachId], references: [id])
  createdAt   DateTime  @default(now())

  members     GroupMembership[]
  challenges  Challenge[]

  @@map("groups")
}

model GroupMembership {
  id        String   @id @default(cuid())
  groupId   String
  athleteId String
  joinedAt  DateTime @default(now())

  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  athlete User  @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([groupId, athleteId])
  @@map("group_memberships")
}

model Challenge {
  id          String        @id @default(cuid())
  groupId     String
  title       String
  description String?
  type        ChallengeType
  sport       Sport         @default(ALL)
  startDate   DateTime
  endDate     DateTime
  createdById String
  createdAt   DateTime      @default(now())

  group     Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy User             @relation(fields: [createdById], references: [id])
  entries   ChallengeEntry[]

  @@map("challenges")
}

model ChallengeEntry {
  id               String   @id @default(cuid())
  challengeId      String
  athleteId        String
  rawValue         Float    // meters, seconds, watts, etc.
  ageGradeScore    Float?   // 0-100 percentage
  stravaActivityId String?
  recordedAt       DateTime @default(now())

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  athlete   User      @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@map("challenge_entries")
}

model Activity {
  id             String   @id @default(cuid())
  athleteId      String
  stravaId       String   @unique
  sportType      String
  name           String?
  distanceM      Float?
  durationS      Int?
  elevationM     Float?
  avgPaceSecPerKm Float?
  avgHr          Float?
  maxHr          Float?
  calories       Int?
  startDate      DateTime
  rawJson        Json?
  createdAt      DateTime @default(now())

  athlete User @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@map("activities")
}
