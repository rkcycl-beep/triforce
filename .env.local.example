# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Database URL for Prisma (Supabase → Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ── Strava ────────────────────────────────────────────────────────────────────
# Client ID is public (safe to expose)
NEXT_PUBLIC_STRAVA_CLIENT_ID=214636
# Client Secret: get from strava.com/settings/api → Show
STRAVA_CLIENT_SECRET=YOUR_CLIENT_SECRET
# Any random string — used to verify Strava webhook calls
STRAVA_WEBHOOK_VERIFY_TOKEN=triforce_webhook_secret_change_me

# ── App ───────────────────────────────────────────────────────────────────────
# Local dev: http://localhost:3000
# Production: https://your-app.vercel.app  (update after first Vercel deploy)
NEXT_PUBLIC_APP_URL=http://localhost:3000
